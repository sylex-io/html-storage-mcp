{
  "name": "html-storage-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "cloudflare": {
    "bindings": {
      "MCP_API_KEY": {
        "description": "Required secret used to authenticate MCP requests. Clients can send it as `Authorization: Bearer <token>` or `?apiKey=<token>`."
      },
      "PUBLIC_BASE_URL": {
        "description": "Optional canonical public base URL for shared pages and OG images, for example `https://share.example.com`. If omitted, the Worker uses its own request origin."
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "dev": "npm run build && wrangler dev --local --port 8787",
    "smoke": "node scripts/smoke-test.mjs",
    "types": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@takumi-rs/image-response": "^0.73.1",
    "@takumi-rs/wasm": "^0.73.1",
    "@vitejs/plugin-react": "^6.0.1",
    "katex": "^0.16.39",
    "mcp-handler": "1.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  }
}
